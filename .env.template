# 8825 System Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: OpenAI API Key
# ============================================================================
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# REQUIRED: System Paths
# ============================================================================
# Path to 8825 system directory (where this file is located)
# Default: ~/8825-system
# Example: /Users/yourname/8825-system
SYSTEM_ROOT=/path/to/8825-system

# Path to your Dropbox root directory
# Default: ~/Dropbox
# Example: /Users/yourname/Dropbox
DROPBOX_ROOT=/path/to/Dropbox

# Path to your Downloads directory
# Default: ~/Downloads
# Example: /Users/yourname/Downloads
DOWNLOADS_DIR=/path/to/Downloads

# Your username for user-specific data
# Default: current system user
# Example: john_doe
USER_NAME=your_username

# ============================================================================
# OPTIONAL: Google API Credentials
# ============================================================================
# Required for: Gmail integration, Calendar sync, Drive uploads
# Get credentials from: https://console.cloud.google.com/

# Path to Google OAuth credentials file
# GOOGLE_CREDENTIALS_PATH=${SYSTEM_ROOT}/8825_core/integrations/google/credentials.json

# Path to Google OAuth token file (auto-generated after first auth)
# GOOGLE_TOKEN_PATH=${SYSTEM_ROOT}/8825_core/integrations/google/token.json

# ============================================================================
# OPTIONAL: Reddit API Credentials
# ============================================================================
# Required for: Reddit integration (beta tester evaluation)
# Get credentials from: https://www.reddit.com/prefs/apps

# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=8825:v3.1.0 (by /u/yourusername)

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# Brain state directory
# Default: ~/.8825/brain_state
# CONFIG_DIR=~/.8825

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Enable debug mode (verbose logging)
# DEBUG=false

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Never commit .env to git (it's in .gitignore)
# 2. Use absolute paths or ~ for home directory
# 3. No quotes needed around values
# 4. Environment variables expand (e.g., ${SYSTEM_ROOT})
# 5. Restart services after changing .env
#
# Quick setup:
#   cp .env.template .env
#   nano .env  # Edit with your values
#   source .env  # Load into current shell (optional)
#
# Verify setup:
#   ./scripts/check_requirements.sh
#
