#!/usr/bin/env python3
"""
8825 brain status
Display current system status from brain daemon
"""

import sys
import json
from pathlib import Path

# Add brain module to path
sys.path.insert(0, str(Path(__file__).parent.parent / "brain"))

from brain_api import BrainAPI

def format_status(status):
    """Format status for display"""
    if "error" in status:
        print(f"❌ Error: {status['error']}")
        if "hint" in status:
            print(f"💡 {status['hint']}")
        return
    
    print("=== Brain Status ===\n")
    
    # System awareness
    awareness = status.get('system_awareness', {})
    print("System Awareness:")
    print(f"  Components: {awareness.get('components', 0)}")
    print(f"  Health: {awareness.get('health', 'unknown')}")
    print(f"  Active workflows: {awareness.get('active_workflows', 0)}")
    print(f"  Last sync: {awareness.get('last_sync', 'never')}")
    print()
    
    # Registry summary
    registry = status.get('registry', {})
    if registry:
        print("Registry:")
        by_type = registry.get('by_type', {})
        for type_name, count in by_type.items():
            print(f"  {type_name}: {count}")
        print()
    
    # Health
    health = status.get('health', {})
    if health.get('overall'):
        print(f"Health: {health['overall']}")
        print()
    
    # Active workflows
    workflows = status.get('active_workflows', [])
    if workflows:
        print(f"Active Workflows ({len(workflows)}):")
        for wf in workflows:
            print(f"  - {wf.get('id', 'unknown')}")
        print()
    
    # Recommendations
    recommendations = status.get('recommendations', [])
    if recommendations:
        print("Recommendations:")
        for rec in recommendations:
            print(f"  {rec}")
        print()
    
    print("Brain sync: ✅ Current")

def main():
    """Main entry point"""
    api = BrainAPI()
    status = api.get_status()
    format_status(status)

if __name__ == "__main__":
    main()
