  "automation_agents": {
    "demo_creation_agent": {
      "name": "Demo Package Creation Agent",
      "version": "2.0.0",
      "description": "Fully automated demo package creation from single command",
      "activation_triggers": [
        "Create demo for [Name], [Company]",
        "Make demo package for [Name]",
        "Generate 8825 demo for [Name] at [Company]",
        "New demo: [Name], [Company]"
      ],
      "workflow": {
        "step_1": {
          "action": "Gather information in one message",
          "questions": [
            "Industry/focus?",
            "Target audience?",
            "Key topic for examples?",
            "Presentation level?",
            "Known pain point? (optional)"
          ]
        },
        "step_2": {
          "action": "Confirm details and execute",
          "show": "Brief confirmation summary"
        },
        "step_3": {
          "action": "Auto-create JSON file",
          "file": "8825_[FirstName]_[Company].json",
          "template": "8825_04-test_MES.json",
          "personalizations": [
            "meta.name",
            "meta.owner",
            "meta.description (industry context)",
            "created_for",
            "dates"
          ]
        },
        "step_4": {
          "action": "Auto-create introduction doc",
          "file": "8825_[FirstName]_[Company]_Introduction.md",
          "template": "8825_Demo_Introduction_TEMPLATE.md",
          "replacements": {
            "[NAME]": "First name",
            "[COMPANY/ROLE]": "Company",
            "[COMPANY]": "Company in examples",
            "[AUDIENCE]": "Their audience",
            "[TOPIC]": "Their topic",
            "[EXECUTIVE LEVEL]": "Their level"
          }
        },
        "step_5": {
          "action": "Show completion summary",
          "include": [
            "Files created",
            "Personalization details",
            "Next steps"
          ]
        }
      },
      "execution_rules": [
        "Ask questions in ONE message",
        "Create files immediately after answers",
        "Use propose_code tool for both files",
        "Show what you did",
        "Provide completion summary",
        "Fully automated - no manual steps"
      ],
      "required_templates": [
        "8825_04-test_MES.json",
        "8825_Demo_Introduction_TEMPLATE.md"
      ],
      "quality_checklist": [
        "Name spelled correctly",
        "Company/role accurate",
        "Examples relevant to industry",
        "Audience matches context",
        "Topic meaningful",
        "Executive level appropriate",
        "Pain point addressed if provided",
        "File names consistent",
        "Dates current"
      ]
    }
  },

  "protocols": {
    "demo_handoff": {
      "name": "Demo Package Handoff Protocol",
      "steps": [
        {
          "step": 1,
          "action": "Create demo package using agent",
          "command": "Create demo for [Name], [Company]"
        },
        {
          "step": 2,
          "action": "Review generated files",
          "verify": ["Personalization accuracy", "Examples relevance", "No errors"]
        },
        {
          "step": 3,
          "action": "Export intro doc to PDF/Word",
          "tool": "Manual export from markdown"
        },
        {
          "step": 4,
          "action": "Send package",
          "include": ["JSON file", "PDF/Word intro", "Optional: setup video"]
        },
        {
          "step": 5,
          "action": "Follow up",
          "timing": "3-5 days",
          "offer": "15-min setup call if needed"
        }
      ]
    },
    
    "basic_mining_setup": {
      "name": "Basic Mining Setup Protocol",
      "prerequisites": ["Demo package delivered", "User interested in mining"],
      "steps": [
        {
          "step": 1,
          "action": "Deliver full 8825 core file",
          "file": "8825_01-core.json or 8825_02-consultant_HCSS.json"
        },
        {
          "step": 2,
          "action": "Set up folder structure",
          "folders": ["- REF -", "- ARCHV -", "projects/"]
        },
        {
          "step": 3,
          "action": "Provide mining prompt",
          "file": "8825_chatgpt_mining_prompt.md"
        },
        {
          "step": 4,
          "action": "Train on workflow",
          "topics": ["Mining conversations", "Saving to REF", "Extracting to projects", "Archiving"]
        },
        {
          "step": 5,
          "action": "First mining session",
          "guidance": "Walk through one complete cycle"
        }
      ],
      "time_estimate": "2-3 hours",
      "deliverables": ["Core file", "Folder structure", "Mining prompt", "Workflow doc", "Training session"]
    },
    
    "automated_setup": {
      "name": "Automated Mining Setup Protocol",
      "prerequisites": ["Basic mining working", "User ready for automation"],
      "steps": [
        {
          "step": 1,
          "action": "Set up Gmail extractor",
          "files": ["8825_gmail_extractor.py", "run_gmail_extractor.command"],
          "config": ["Gmail credentials", "Routing rules", "Duplicate prevention"]
        },
        {
          "step": 2,
          "action": "Set up archive automation",
          "files": ["8825_archive_ref.py", "run_archive_ref.command"]
        },
        {
          "step": 3,
          "action": "Configure Windsurf workspace",
          "setup": ["Core file in workspace", "Project files structure", "Interaction logging"]
        },
        {
          "step": 4,
          "action": "Test automation",
          "verify": ["Email extraction", "Routing accuracy", "Archiving", "File updates"]
        },
        {
          "step": 5,
          "action": "Train on automated workflow",
          "topics": ["Running extractors", "Reviewing REF", "Extracting with Windsurf", "Archiving"]
        }
      ],
      "time_estimate": "1 day",
      "deliverables": ["All scripts", "Configured workspace", "Tested automation", "Training"]
    }
  },

