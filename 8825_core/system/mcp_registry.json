    "fds": {
      "location": "~/mcp_servers/fds/",
      "type": "stdio",
      "language": "python",
      "description": "FDS integration"
    },
    "meeting_automation": {
      "location": "~/mcp_servers/meeting-automation/",
      "type": "stdio",
      "language": "python",
