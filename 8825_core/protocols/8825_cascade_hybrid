## Protocol Consultation API

### Internal Decision Function
```javascript
function shouldConsultProtocol(task, protocol) {
  const relevance = calculateRelevance(task, protocol);
  const improvement = estimateImprovement(task, protocol);
  const preference = getUserPreference(protocol);
  const threshold = getThreshold(protocol, preference);
  
  return (relevance * improvement) > threshold;
}
```

### Consultation Application
```javascript
function applyProtocolConsultation(task, protocol, mode) {
  const guidance = consultProtocol(protocol, task);
  const approach = integrateGuidance(defaultApproach, guidance);
  
  if (mode === 'transparent') {
    explainConsultation(protocol, guidance, approach);
  }
  
  return approach;
}
```

