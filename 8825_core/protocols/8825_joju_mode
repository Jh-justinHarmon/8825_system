  "deduplication_phase": {
    "title": "Phase 3: Smart Deduplication & Enrichment",
    "description": "Compare mined content with master library, dedupe, merge, and enrich",
    "dedup_agent_role": "Identify duplicates, merge information, enrich existing entries",
    "enforcement": "MANDATORY - Must complete before updating library or publishing",
    "user_review_required": true,
    "strategies": {
      "exact_match": {
        "description": "Identical text or very high similarity (>95%)",
        "action": "Skip or flag for review"
      },
      "semantic_match": {
        "description": "Same achievement described differently",
        "detection": "Compare action, metric, outcome semantically",
        "action": "Merge and keep best version or combine details"
      },
      "enrichment_opportunity": {
        "description": "New information adds to existing entry",
        "examples": [
          "New metric for existing project",
          "Additional context for achievement",
          "Updated date range for role",
          "New skill proficiency level"
        ],
        "action": "Merge new information into existing entry"
      },
      "version_reconciliation": {
        "description": "Multiple resume versions with overlapping content",
        "action": "Extract unique information from each, consolidate into single source of truth"
      },
      "conflict_resolution": {
        "description": "Contradictory information between sources",
        "action": "Flag for user review, prefer most recent or most detailed source"
      }
    },
    "dedup_rules": {
      "achievements": {
        "match_criteria": ["same_company", "same_timeframe", "similar_metric"],
        "merge_strategy": "Combine details, keep highest metric, preserve all context"
      },
      "projects": {
        "match_criteria": ["same_project_name", "same_date_range"],
        "merge_strategy": "Combine descriptions, merge technology lists, preserve all outcomes"
      },
      "skills": {
        "match_criteria": ["same_skill_name"],
        "merge_strategy": "Keep highest proficiency level, combine contexts"
      },
      "work_experience": {
        "match_criteria": ["same_company", "same_title", "overlapping_dates"],
        "merge_strategy": "Extend date range if needed, merge achievements, combine responsibilities"
      }
    },
    "dedup_output": {
      "location": "/joju_sandbox/deduped/",
      "reports": [
        "dedup_analysis.json (complete analysis with recommendations)",
        "dedup_summary.json (stats: duplicates found, merged, enriched)",
        "conflicts.json (items needing user review)",
        "enrichment_log.json (what was added to existing entries)"
      ]
    },
    "workflow_checkpoint": {
      "description": "STOP HERE - Present dedup analysis to user for review",
      "required_actions": [
        "Generate dedup_analysis.json with all findings",
        "Present summary to user with key decisions",
