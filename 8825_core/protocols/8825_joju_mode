  "library_first_workflow": {
    "title": "LIBRARY-FIRST WORKFLOW (v2.0)",
    "description": "Master library is single source of truth, updated FIRST before Joju input",
    "philosophy": "Library stores ALL achievements, Joju input is curated view of library",
    
    "workflow_steps": {
      "step_1_extract": {
        "title": "Extract from Source",
        "actions": [
          "Mine source content using 8825_mining protocol",
          "Create achievements JSON in /joju_sandbox/mined/",
          "Include: achievement text, metrics, evidence, confidence scores, source reference"
        ],
        "output": "/joju_sandbox/mined/{source}_achievements.json"
      },
      
      "step_2_merge_to_library": {
        "title": "Merge to Master Library (AUTOMATIC)",
        "description": "Add achievements to master library FIRST, with auto-dedup",
        "actions": [
          "Load JH_master_library.json",
          "For each mined achievement:",
          "  - Check for semantic duplicates in library (>80% similarity)",
          "  - If duplicate: mark as enrichment opportunity, merge details",
          "  - If new: add to library with 'pending_joju' status",
          "  - Tag with: source, timestamp, confidence_score, joju_status",
          "Save updated library",
          "Generate merge report"
        ],
        "dedup_logic": {
          "semantic_matching": "Use embedding similarity or keyword overlap",
          "threshold": "80% similarity = duplicate",
          "merge_strategy": "Enrich existing with new metrics/evidence, keep highest confidence",
          "conflict_resolution": "Flag for user review if contradictory"
        },
        "output": {
          "updated_library": "JH_master_library.json",
          "merge_report": "/joju_sandbox/merged/{source}_merge_report.json"
        }
      },
      
      "step_3_present_changes": {
        "title": "Present Changes to User",
        "description": "Show streamlined summary of what's new/enriched",
        "format": {
          "summary": "X new achievements, Y enrichments, Z duplicates skipped",
          "new_achievements": "List with confidence scores",
          "enrichments": "Show before/after for existing achievements",
          "duplicates_skipped": "List what was merged"
        },
        "user_prompt": "Add these to Joju input? [Yes/No/Select specific]"
      },
      
      "step_4_update_joju_input": {
        "title": "Update Joju Input (FROM LIBRARY)",
        "description": "Pull approved achievements from library into Joju input",
        "actions": [
          "For each approved achievement:",
          "  - Pull from library (with all enrichments)",
          "  - Format for Joju readCV structure",
          "  - Add to appropriate section (workExperience, projects, etc.)",
          "  - Update library: mark as 'active_in_joju'",
          "Validate JSON structure",
          "Save justin_harmon_joju_input.json"
        ],
        "library_tracking": "Each achievement in library tracks: in_joju (true/false), joju_section, date_added_to_joju"
      },
      
      "step_5_version": {
        "title": "Create Versioned Copies",
        "actions": [
          "Increment revision number",
          "Copy both library and Joju input to 8825X76 sandbox/",
          "Naming: {filename}_{rev#}-{source-type}.json",
          "Update library session log"
        ],
        "output": {
          "library_copy": "JH_master_library_{rev#}-{source}.json",
          "joju_copy": "justin_harmon_joju_input_{rev#}-{source}.json"
        }
      }
    },
    
    "efficiency_optimizations": {
      "auto_dedup": "Semantic matching happens automatically, no manual comparison needed",
      "single_update": "Library updated once, Joju input pulls from it (not separate updates)",
      "smart_merge": "Enriches existing vs creating duplicates",
      "minimal_user_friction": "User only approves final Joju changes, library updates are automatic",
