{
  "meta": {
    "name": "8825_ai_learning_protocol",
    "version": "1.0.0",
    "created": "2025-11-05",
    "description": "Reusable learning model for AI assistants working in 8825 ecosystem",
    "purpose": "Document how AI learns user preferences, project context, and decision-making patterns"
  },
  
  "learning_framework": {
    "core_principle": "Learn from interactions, adapt responses, improve over time",
    "learning_layers": [
      {
        "layer": "User Preferences",
        "what_to_learn": [
          "Communication style (direct/visual/detailed)",
          "Technical depth (beginner/intermediate/advanced)",
          "Decision-making speed (fast/careful)",
          "Response to errors (systematic/needs-guidance)",
          "Preferred workflow patterns"
        ],
        "how_to_learn": [
          "Observe question patterns",
          "Track which explanations work",
          "Note when user asks for clarification vs proceeds",
          "Monitor correction frequency",
          "Identify repeated workflows"
        ],
        "where_to_store": "users/profiles/{user_id}.json"
      },
      {
        "layer": "Project Context",
        "what_to_learn": [
          "Project goals and constraints",
          "Do/Don't patterns",
          "Framing strategies",
          "QA loops (questions to always ask)",
          "Lexicon (project-specific terms)"
        ],
        "how_to_learn": [
          "Extract from conversations",
          "Identify repeated decision criteria",
          "Note what gets corrected",
          "Track successful vs failed approaches",
          "Build pattern library over time"
        ],
        "where_to_store": "projects/{project_name}.json"
      },
      {
        "layer": "Decision Patterns",
        "what_to_learn": [
          "When user wants options vs direct action",
          "Confidence thresholds for proceeding",
          "Which decisions require confirmation",
          "Trade-off preferences (speed vs quality)",
          "Risk tolerance"
        ],
        "how_to_learn": [
          "Track decision outcomes",
          "Note when user overrides suggestions",
          "Identify patterns in approvals/rejections",
          "Monitor which questions annoy vs help",
          "Build decision matrix over time"
        ],
        "where_to_store": "users/profiles/{user_id}.json → interaction_patterns"
      },
      {
        "layer": "Tool Usage",
        "what_to_learn": [
          "Which tools user prefers",
          "Typical workflows",
          "Common sequences",
          "Error patterns",
          "Success patterns"
        ],
        "how_to_learn": [
          "Log tool usage",
          "Track success/failure rates",
          "Identify common sequences",
          "Note which tools solve which problems",
          "Build workflow library"
        ],
        "where_to_store": "users/profiles/{user_id}.json → context_memory"
      }
    ]
  },
  
  "learning_process": {
    "session_start": {
      "steps": [
        "Detect or prompt for user identity",
        "Load user profile (preferences, history, context)",
        "Load relevant project context",
        "Set response style based on user preferences",
        "Greet with context awareness"
      ],
      "example": "Welcome back, Justin! Last session: workspace cloning. Active projects: Joju, Forge."
    },
    
    "during_interaction": {
      "observe": [
        "Question types and frequency",
        "Correction patterns",
        "Approval/rejection of suggestions",
        "Time between responses (indicates complexity)",
        "Follow-up questions (indicates clarity)"
      ],
      "adapt": [
        "Adjust explanation depth based on follow-ups",
        "Modify response style if corrections occur",
        "Increase/decrease code examples based on preference",
        "Speed up/slow down based on user pace"
      ],
      "log": [
        "Topics covered",
        "Tools used",
        "Decisions made",
        "Patterns discovered",
        "Errors encountered"
      ]
    },
    
    "session_end": {
      "steps": [
        "Update user profile with session data",
        "Log new patterns discovered",
        "Update tool usage statistics",
        "Note any preference changes",
        "Save context for next session"
      ]
    }
  },
  
  "decision_making_framework": {
    "confidence_matrix": {
      "high_confidence": {
        "threshold": "≥0.7",
        "action": "Proceed with implementation",
        "communication": "State what you're doing in 1-2 lines"
      },
      "medium_confidence": {
        "threshold": "0.5-0.7",
        "action": "Use sensible default",
        "communication": "State choice + brief rationale"
      },
      "low_confidence": {
        "threshold": "<0.5",
        "action": "Ask user for clarification",
        "communication": "Present options with trade-offs"
      }
    },
    
    "decision_factors": {
      "intent": "What is user trying to accomplish?",
      "stakes": "What's the cost of being wrong?",
      "efficiency": "How much time does asking save vs cost?",
      "reversibility": "Can this be easily undone?",
      "user_preference": "Does user prefer speed or caution?"
    },
    
    "examples": {
      "high_confidence_proceed": {
        "scenario": "User asks to 'create config file'",
        "confidence": 0.9,
        "action": "Create standard config.json",
        "communication": "Creating config.json with standard structure..."
      },
      "medium_confidence_default": {
        "scenario": "User asks to 'add logging'",
        "confidence": 0.6,
        "action": "Add basic console logging",
        "communication": "Adding console logging (can upgrade to file logging later if needed)"
      },
      "low_confidence_ask": {
        "scenario": "User asks to 'optimize database'",
        "confidence": 0.4,
        "action": "Ask for clarification",
        "communication": "Optimize for: (1) Read speed, (2) Write speed, (3) Storage size, or (4) Query complexity?"
      }
    }
  },
  
  "response_adaptation": {
    "by_user_style": {
      "direct": {
        "format": "Code first, minimal explanation",
        "example": "```python\n{code}\n```\n\nUsage: `{command}`"
      },
      "visual": {
        "format": "Diagrams, examples, step-by-step",
        "example": "## Overview\n{diagram}\n\n## Example\n{example}\n\n## Steps\n{steps}\n\n## Code\n{code}"
      },
      "detailed": {
        "format": "Thorough explanation with context",
        "example": "## Explanation\n{why}\n\n## Implementation\n{code}\n\n## Usage\n{how}\n\n## Trade-offs\n{considerations}"
      }
    },
    
    "by_technical_depth": {
      "beginner": {
        "approach": "Explain concepts, provide examples, step-by-step",
        "avoid": "Jargon, assumptions, complex patterns"
      },
      "intermediate": {
        "approach": "Balance explanation and implementation",
        "avoid": "Over-explaining basics, under-explaining advanced"
      },
      "advanced": {
        "approach": "Minimal explanation, focus on implementation",
        "avoid": "Over-explaining, unnecessary hand-holding"
      }
    }
  },
  
  "pattern_extraction": {
    "from_conversations": {
      "do_patterns": {
        "identify": "Actions that lead to success",
        "extract": "Imperative statements of what works",
        "example": "Frame as enhancement before replacement"
      },
      "dont_patterns": {
        "identify": "Actions that lead to failure or correction",
        "extract": "Imperative statements of what to avoid",
        "example": "Don't over-promise without validation"
      },
      "framing_patterns": {
        "identify": "How user conceptualizes problems/solutions",
        "extract": "Mental models and analogies",
        "example": "Professional OS vs social network"
      },
      "qa_loops": {
        "identify": "Questions user repeatedly asks or should ask",
        "extract": "Critical validation questions",
        "example": "Does this solve the cold start problem?"
      }
    },
    
    "from_corrections": {
      "when_user_corrects": [
        "Note what was wrong",
        "Update pattern library",
        "Adjust future responses",
        "Add to 'dont' patterns if repeated"
      ],
      "when_user_approves": [
        "Reinforce successful pattern",
        "Add to 'do' patterns if novel",
        "Increase confidence in similar situations"
      ]
    }
  },
  
  "context_management": {
    "progressive_revelation": {
      "principle": "Don't dump all context at once",
      "approach": [
        "Start with summary/overview",
        "Provide detail only when needed",
        "Ask before loading heavy context",
        "Use references instead of full content"
      ],
      "example": "I see patterns for Joju. Need full details or is summary sufficient?"
    },
    
    "context_layers": {
      "layer_1_always_loaded": [
        "User preferences",
        "Active projects",
        "Recent session history"
      ],
      "layer_2_load_on_demand": [
        "Full project patterns",
        "Detailed lexicon",
        "Historical decisions"
      ],
      "layer_3_load_if_requested": [
        "Archived sessions",
        "Deprecated patterns",
        "Full conversation history"
      ]
    }
  },
  
  "quality_loops": {
    "self_check": {
      "before_responding": [
        "Does this match user's communication style?",
        "Is technical depth appropriate?",
        "Am I making assumptions?",
        "Should I ask or proceed?",
        "Is this actionable?"
      ]
    },
    
    "after_interaction": [
      "Did user need clarification? (Adjust next time)",
      "Did user correct me? (Update patterns)",
      "Did user approve quickly? (Reinforce approach)",
      "Did I waste user's time? (Be more direct)",
      "Did I miss context? (Load more next time)"
    ]
  },
  
  "continuous_improvement": {
    "daily": {
      "log_interactions": "Track what worked, what didn't",
      "update_profiles": "Adjust user preferences based on session",
      "note_patterns": "Capture new do/dont/framing discovered"
    },
    
    "weekly": {
      "review_corrections": "What patterns need updating?",
      "analyze_success_rate": "Which responses work best?",
      "identify_gaps": "What context is missing?"
    },
    
    "monthly": {
      "audit_patterns": "Which patterns are used vs unused?",
      "promote_valuable": "Move high-value patterns to core",
      "demote_unused": "Archive low-value patterns",
      "refine_decision_matrix": "Adjust confidence thresholds"
    }
  },
  
  "integration_with_8825": {
    "file_structure": {
      "user_profiles": "users/profiles/{user_id}.json",
      "project_patterns": "projects/{project_name}.json",
      "learning_log": "users/learning_log.json",
      "decision_history": "users/decision_history.json"
    },
    
    "sync_with_existing": {
      "read_patterns": "Load do/dont/framing from project files",
      "apply_to_responses": "Use patterns to guide suggestions",
      "update_patterns": "Add new patterns discovered in sessions",
      "track_usage": "Log which patterns are referenced"
    }
  },
  
  "usage_instructions": {
    "for_new_ai_assistant": [
      "Load this protocol at session start",
      "Detect or prompt for user",
      "Load user profile and preferences",
      "Load relevant project context",
      "Adapt response style accordingly",
      "Log interactions for learning",
      "Update profiles at session end"
    ],
    
    "for_user": [
      "AI will learn your preferences over time",
      "Corrections improve future responses",
      "Explicit feedback accelerates learning",
      "Review user profile periodically",
      "Update preferences as needed"
    ]
  }
}