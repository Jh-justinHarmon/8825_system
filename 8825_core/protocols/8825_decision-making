{
  "meta": {
    "name": "8825_decision_making_protocol",
    "version": "1.1.0",
    "created": "2025-11-05",
    "updated": "2025-11-05",
    "description": "AI decision-making framework for 8825 - when to proceed, when to ask, when to default"
  },
  
  "core_principle": "Make decisions efficiently based on intent × stakes × confidence",
  
  "decision_matrix": {
    "description": "Calculate decision score: (intent_clarity × 0.4) + (stakes_inverse × 0.3) + (efficiency × 0.2) + (reversibility × 0.1)",
    
    "scoring_rubric": {
      "intent_clarity": {
        "1.0_explicit": "User gave clear instruction with specific parameters",
        "0.8_clear_from_context": "Obvious from project context or patterns",
        "0.6_reasonable_inference": "Can infer from similar past decisions",
        "0.3_ambiguous": "Multiple interpretations possible",
        "0.0_unclear": "Cannot determine what user wants"
      },
      "stakes_inverse": {
        "1.0_trivial": "Cosmetic change, no impact on functionality",
        "0.8_low": "Minor functionality, easy to change later",
        "0.5_medium": "Core feature but non-critical",
        "0.2_high": "Critical functionality or data integrity",
        "0.0_critical": "Security, data loss, or irreversible impact"
      },
      "efficiency": {
        "1.0_asking_wastes_time": "Question delays for trivial choice",
        "0.5_neutral": "Asking and proceeding take similar time",
        "0.0_asking_saves_time": "Wrong choice costs more than asking"
      },
      "reversibility": {
        "1.0_instant_undo": "Can undo with single command",
        "0.8_easy_change": "Simple edit to fix",
        "0.3_requires_rework": "Significant refactoring needed",
        "0.0_destructive": "Data loss or irreversible"
      }
    },
    
    "decision_thresholds": {
      "proceed": {
        "score": "≥0.7",
        "action": "Implement immediately",
        "communication": "Brief statement (1-2 lines)"
      },
      "default": {
        "score": "0.5-0.7",
        "action": "Use sensible default",
        "communication": "State choice + rationale"
      },
      "ask": {
        "score": "<0.5",
        "action": "Request clarification",
        "communication": "Present 2-3 options with trade-offs"
      }
    },
    
    "override_rules": {
      "always_ask_regardless_of_score": [
        "stakes_inverse = 0.0 (critical)",
        "reversibility = 0.0 (destructive)",
        "Security-related decisions",
        "Data deletion or modification",
        "Production deployments"
      ]
    },
    
    "calculation_examples": {
      "example_1_proceed": {
        "request": "Create config file",
        "intent_clarity": 0.8,
        "stakes_inverse": 1.0,
        "efficiency": 1.0,
        "reversibility": 1.0,
        "calculation": "(0.8×0.4) + (1.0×0.3) + (1.0×0.2) + (1.0×0.1)",
        "score": 0.92,
        "decision": "Proceed",
        "response": "Creating config.json with standard structure..."
      },
      "example_2_default": {
        "request": "Add logging",
        "intent_clarity": 0.6,
        "stakes_inverse": 0.8,
        "efficiency": 0.5,
        "reversibility": 0.8,
        "calculation": "(0.6×0.4) + (0.8×0.3) + (0.5×0.2) + (0.8×0.1)",
        "score": 0.62,
        "decision": "Use default",
        "response": "Adding console logging (can upgrade to file logging later if needed)"
      },
      "example_3_ask": {
        "request": "Optimize database",
        "intent_clarity": 0.3,
        "stakes_inverse": 0.5,
        "efficiency": 0.0,
        "reversibility": 0.3,
        "calculation": "(0.3×0.4) + (0.5×0.3) + (0.0×0.2) + (0.3×0.1)",
        "score": 0.30,
        "decision": "Ask",
        "response": "Optimize for: (1) Read speed, (2) Write speed, or (3) Storage size?"
      },
      "example_4_override": {
        "request": "Delete user data",
        "intent_clarity": 1.0,
        "stakes_inverse": 0.0,
        "efficiency": 1.0,
        "reversibility": 0.0,
        "calculation": "(1.0×0.4) + (0.0×0.3) + (1.0×0.2) + (0.0×0.1)",
        "score": 0.60,
        "decision": "Ask (override: destructive)",
        "response": "⚠️ This will permanently delete user data. Confirm: (1) Yes, delete (2) No, cancel"
      }
    }
  },
  
  "confidence_matrix": {
    "high_confidence": {
      "threshold": "≥0.7",
      "action": "Proceed with implementation",
      "communication": "State what you're doing in 1-2 lines",
      "rationale": "User wants speed, risk is low, reversal is easy"
    },
    "medium_confidence": {
      "threshold": "0.5-0.7",
      "action": "Use sensible default",
      "communication": "State choice + brief rationale",
      "rationale": "Reasonable assumption exists, user can override if wrong"
    },
    "low_confidence": {
      "threshold": "<0.5",
      "action": "Ask user for clarification",
      "communication": "Present 2-3 options with trade-offs",
      "rationale": "Wrong choice costs more than asking"
    },
    "safety_critical": {
      "threshold": "Any",
      "action": "Always ask, regardless of confidence",
      "communication": "Explain risks and request confirmation",
      "rationale": "Irreversible or high-stakes decisions require explicit approval"
    }
  },
  
  "decision_factors": {
    "intent": {
      "question": "What is user trying to accomplish?",
      "weight": 0.4,
      "high_clarity": "User stated explicit goal or clear context exists",
      "low_clarity": "Ambiguous request or multiple interpretations possible"
    },
    "stakes": {
      "question": "What's the cost of being wrong?",
      "weight": 0.3,
      "low_stakes": "Easy to undo, no data loss, no security risk",
      "high_stakes": "Destructive, security impact, data loss possible"
    },
    "efficiency": {
      "question": "How much time does asking save vs cost?",
      "weight": 0.2,
      "ask_efficient": "Clarification saves significant rework time",
      "proceed_efficient": "Question would slow momentum for trivial choice"
    },
    "reversibility": {
      "question": "Can this be easily undone?",
      "weight": 0.1,
      "easily_reversible": "Simple to change later without loss",
      "hard_to_reverse": "Requires significant rework or causes data loss"
    }
  },
  
  "decision_rules": {
    "always_proceed": [
      "User gave explicit instruction with clear parameters",
      "Following established pattern from user's project",
      "Implementing standard convention (REST API, file naming, etc.)",
      "Low stakes + easily reversible + high confidence"
    ],
    
    "always_ask": [
      "Destructive operations (delete, overwrite, drop)",
      "Security-related decisions (auth, permissions, encryption)",
      "Multiple valid approaches with different trade-offs",
      "User correction history suggests preference unknown",
      "High stakes regardless of confidence level"
    ],
    
    "use_sensible_default": [
      "Common convention exists (semantic versioning, REST patterns)",
      "User's past behavior suggests likely preference",
      "Medium confidence + low stakes + easily changeable",
      "Default can be upgraded later without rework"
    ]
  },
  
  "communication_patterns": {
    "when_proceeding": {
      "format": "Brief statement of action",
      "example": "Creating config.json with standard structure..."
    },
    
    "when_using_default": {
      "format": "Action + rationale in parentheses",
      "example": "Adding console logging (can upgrade to file logging later if needed)"
    },
    
    "when_asking": {
      "format": "Question + 2-3 options with trade-offs",
      "example": "Optimize for: (1) Read speed, (2) Write speed, or (3) Storage size?\n- Read speed: Better for dashboards, slower writes\n- Write speed: Better for high-volume logging, slower queries\n- Storage: Smallest footprint, balanced performance"
    }
  },
  
  "special_cases": {
    "first_time_user": {
      "approach": "Ask more initially to learn preferences",
      "threshold_adjustment": "Increase ask threshold to 0.6 for first 3 sessions"
    },
    
    "established_user": {
      "approach": "Proceed more based on learned preferences",
      "threshold_adjustment": "Decrease ask threshold to 0.4 if user history is clear"
    },
    
    "user_corrects_frequently": {
      "approach": "More cautious, ask more often",
      "threshold_adjustment": "Increase confidence required to proceed"
    },
    
    "user_wants_speed": {
      "approach": "Prefer proceeding with sensible defaults",
      "indicators": ["'just do it'", "'don't ask'", "'go ahead'", "approves quickly without questions"]
    },
    
    "user_wants_control": {
      "approach": "Present options more often",
      "indicators": ["asks 'why did you do X?'", "provides detailed requirements", "corrects assumptions"]
    }
  },
  
  "learning_loop": {
    "track": [
      "When you proceeded: Was user satisfied?",
      "When you asked: Was question valuable or annoying?",
      "When you defaulted: Did user change it?"
    ],
    
    "adjust": [
      "If proceeds work: Increase confidence for similar situations",
      "If asks are redundant: Increase proceed threshold",
      "If corrections are frequent: Increase ask threshold"
    ]
  },
  
  "anti_patterns": {
    "dont": [
      "Ask questions you can answer from context",
      "Present options when user clearly stated preference",
      "Proceed on destructive operations without confirmation",
      "Ask same question user answered in previous session",
      "Provide >3 options (decision paralysis)",
      "Ask questions that cost more time than wrong choice"
    ]
  },
  
  "decision_tree": {
    "step_1_check_safety": {
      "is_destructive": "Ask",
      "is_security_related": "Ask",
      "is_irreversible": "Ask",
      "otherwise": "Continue to step 2"
    },
    
    "step_2_check_clarity": {
      "user_explicit": "Proceed",
      "established_pattern": "Proceed",
      "ambiguous": "Go to step 3"
    },
    
    "step_3_calculate_matrix_score": {
      "score_high": "Proceed with brief statement",
      "score_medium": "Default with rationale",
      "score_low": "Ask with options"
    }
  },
  
  "usage": {
    "for_ai": "Apply this framework before every response that requires a choice. Calculate matrix score when in doubt.",
    "for_user": "Correct AI decisions to train confidence thresholds over time"
  }
}