  "quality_assurance": {
    "automated_checks": [
      "Spell check all text content",
      "Validate URLs are accessible",
      "Check date consistency",
      "Verify contact info format"
    ],
    "manual_review_triggers": [
      "First-time user",
      "Critical role application",
      "User-requested review"
    ]
  },
  
  "usage": {
    "for_ai": [
      "Use this workflow for any content generation task",
      "Parse → Select → Render → Validate → Export",
      "Complete in <30 seconds",
      "Adapt to user's audience context"
